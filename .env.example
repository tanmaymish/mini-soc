# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=mini_soc

# Flask
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-me-in-production

# Detection Thresholds
BRUTE_FORCE_THRESHOLD=5
BRUTE_FORCE_WINDOW_SECONDS=60
PORT_SCAN_THRESHOLD=10
PORT_SCAN_WINDOW_SECONDS=30

# Alerting
# Set this to a Slack/Discord webhook URL to receive external notifications
WEBHOOK_URL=
# Only alerts with this severity or higher will trigger webhooks (low, medium, high, critical)
ALERT_MIN_SEVERITY=high
